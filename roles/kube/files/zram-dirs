#!/sbin/openrc-run

depend() {
    need localmount
    before logger metalog syslog syslog-ng busybox-syslog \
        k0scontroller cron dbus
}

start() {
    ebegin "Mounting dirs to zram"
    /usr/local/bin/zram-dir /var/lib/k0s/etcd 1G
    /usr/local/bin/zram-dir /var/log 512M
    eend $?
}

stop() {
    ebegin "Unmounting dirs from zram"
    /usr/local/bin/zram-dir /var/lib/k0s/etcd
    /usr/local/bin/zram-dir /var/log
    eend $?
}
