#!/sbin/openrc-run

depend() {
    need localmount
    after postmarketos-zram-swap
    before k0scontroller
}

start() {
    ebegin "Mounting k0s dirs to zram"
    /usr/local/bin/k0s-zram.sh --mount
    eend $?
}

stop() {
    ebegin "Unmounting k0s dirs from zram"
    /usr/local/bin/k0s-zram.sh --umount
    eend $?
}
