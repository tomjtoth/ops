[Unit]
Description=port forward for Longhorn
After=network-online.target kube-tunnel.service
Wants=network-online.target
Requires=kube-tunnel.service

[Service]
Type=simple
Restart=always
RestartSec=10
ExecStart=kubectl -n longhorn-system port-forward svc/longhorn-frontend 55527:80

[Install]
WantedBy=default.target
