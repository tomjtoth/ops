[Unit]
Description=port forward for Longhorn
After=network-online.target wg-quick@wg0.service
Wants=network-online.target
Requires=wg-quick@wg0.service

[Service]
Type=simple
Restart=always
RestartSec=10
ExecStart=kubectl -n longhorn-system port-forward svc/longhorn-frontend 55527:80

[Install]
WantedBy=default.target
