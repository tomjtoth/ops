[Unit]
Description=port forward for ArgoCD
After=network-online.target kube-tunnel.service
Wants=network-online.target
Requires=kube-tunnel.service

[Service]
Type=simple
Restart=always
RestartSec=10
ExecStart=kubectl -n argocd port-forward svc/argocd-server 55526:80

[Install]
WantedBy=default.target
