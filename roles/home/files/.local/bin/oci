#!/bin/bash

set -eu

# config and keys are stored here on this host
PERSISTENT_OCI=~/.oci

# user oracle is 1000:1000 in the oci-cli container
# also set key_file=/absolute/path/to/private/key
sudo chown -hR 1000:1000 "$PERSISTENT_OCI"

COMPARTMENT_ID=$(sudo grep 'tenancy' "$PERSISTENT_OCI/config" | cut -d'=' -f2)

SYSTEMD_SERVICE=$(cat <<SYSTEMD_SERVICE
[Unit]
Description=oci cli compute instance creator
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=%h/.local/bin/oci --launch %h/.ssh/id_oci.pub --as-service

[Install]
WantedBy=default.target
SYSTEMD_SERVICE
)

DOCKER_IT="-it"

__run(){
    [ -v DEBUG ] && set -x
    docker run --rm $DOCKER_IT -v "$PERSISTENT_OCI:/oracle/.oci" ghcr.io/oracle/oci-cli "$@"
    RC=$?
    [ -v DEBUG ] && { set +x; } 2>/dev/null
}

__list_all(){
    __run compute instance list --all --compartment-id "$COMPARTMENT_ID"
}


# defaults
DISPLAY_NAME=MaxedOutAlwaysFreeVM
SHAPE=VM.Standard.A1.Flex
SHAPE_CONFIG='{"ocpus":1,"memoryInGBs":1}'
BOOT_VOLUME_SIZE_IN_GBS=50
RETRY_TIMEOUT=90s

USAGE=$(cat <<EOF

proper usage: $(basename $0) [<anything suitable for the oci image> | --list-all | --launch "path/to/public/ssh/key" [OVERRIDES] | --user-service <enable | disable>]

where OVERRIDES for --launch with their defaults:
  --display-name                "$DISPLAY_NAME"
  --shape                       "$SHAPE"
  --shape-config                '$SHAPE_CONFIG'
  --boot-volume-size-in-gbs     $BOOT_VOLUME_SIZE_IN_GBS
  
  --retry-timeout               $RETRY_TIMEOUT


EOF
)

__parse_overrides(){
    while [ $# -gt 0 ]; do
        case "$1" in
            --as-service)
                DOCKER_IT=""
                ;;

            --retry-timeout)
                RETRY_TIMEOUT=$2
                shift
                ;;

            --display-name) 
                DISPLAY_NAME=$2
                shift
                ;;

            --shape)
                SHAPE=$2
                shift
                ;;

            --shape-config)
                SHAPE_CONFIG="$2"
                shift
                ;;

            --boot-volume-size-in-gbs)
                BOOT_VOLUME_SIZE_IN_GBS=$2
                shift
                ;;

            *) UNKNOWN_OVERRIDES+=("$1") ;;
        esac
        shift
    done

    if [ -v UNKNOWN_OVERRIDES ]; then
        echo -e "\n\tUnknown overrides: ${UNKNOWN_OVERRIDES[@]}\n"
        exit 1
    fi
}

__launch(){
    SSH_KEY=$(cat "$2")

    if [ $# -lt 2 ] || (! ssh-keygen -lf <(printf '%s\n' "$SSH_KEY") >/dev/null 2>&1); then
        echo "$USAGE"
        exit 1
    fi

    shift 2
    
    __parse_overrides "$@"

    AD_NAME=$(__run iam availability-domain list \
        --compartment-id "$COMPARTMENT_ID" | \
        jq -r '.data[0].name')

    SUBNET_OCID=$(__run network subnet list \
        --compartment-id "$COMPARTMENT_ID" --all | \
        jq -r '.data[0].id')

    IMAGE_OCID=$(__run compute image list \
        --compartment-id "$COMPARTMENT_ID" \
        --operating-system "Canonical Ubuntu" \
        --shape $SHAPE --all | \
        jq -r '
            .data
            | max_by(."display-name")
            | .id
        ')

    METADATA=$(jq -nc --arg key "$SSH_KEY" '{ssh_authorized_keys: $key}')

    set +e
    until __list_all | grep -q '"display-name": "'$DISPLAY_NAME'",'; do
        __run compute instance launch \
            --availability-domain "$AD_NAME" \
            --compartment-id "$COMPARTMENT_ID" \
            --subnet-id "$SUBNET_OCID" \
            --image-id "$IMAGE_OCID" \
            --assign-public-ip true \
            --display-name "$DISPLAY_NAME" \
            --shape $SHAPE \
            --shape-config $SHAPE_CONFIG \
            --metadata "$METADATA" \
            --boot-volume-size-in-gbs $BOOT_VOLUME_SIZE_IN_GBS

        [ $RC -eq 0 ] && break
        
        echo -e "\n\tretrying in $RETRY_TIMEOUT...\n"
        sleep $RETRY_TIMEOUT
    done

    echo -e "\n\tCreated $DISPLAY_NAME\n"
}

__user_service(){
    local svc_path=~/.config/systemd/user/oci.service

    if [ "$1" == "enable" ]; then
        mkdir -p ${svc_path%/*}|| true
        echo "$SYSTEMD_SERVICE" > "$svc_path"
    
        systemctl --user daemon-reload
        systemctl --user enable --now oci
    else
        systemctl --user disable --now oci
    fi
}

case "${1:---help}" in 
    --list-all) __list_all ;;
    --launch) __launch "$@" ;;
    --user-service) __user_service $2 ;;

    -h|--help)
        echo -e "\n### TTJ ###\n$USAGE\n### OCI ###\n"
        __run "$@"
        ;;

    *) __run "$@" ;; 
esac
